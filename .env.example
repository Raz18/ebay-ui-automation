# eBay E2E Automation Framework - Environment Variables
# Copy this file to .env and adjust values as needed.
# All variables are optional - defaults are defined in config/settings.py.

# eBay base URL (default: https://www.ebay.com)
EBAY_BASE_URL=https://www.ebay.com

# Browser settings
HEADLESS=true
BROWSER=chromium
BROWSER_CHANNEL=chrome
SLOW_MO=0
BROWSER_LOCALE=en-US
TIMEZONE_ID=America/New_York
ACCEPT_LANGUAGE=en-US,en;q=0.9

# Currency validation
PREFERRED_CURRENCY=USD
STRICT_CURRENCY_VALIDATION=false

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
LOCATOR_ATTEMPT_TIMEOUT=5000

# Retry configuration
MAX_RETRIES=3
BACKOFF_FACTOR=2.0

# Screenshots
SCREENSHOT_ON_FAILURE=true

# Reporting
REPORTS_DIR=reports

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# eBay credentials (for login tests - leave empty to skip login)
EBAY_USERNAME=
EBAY_PASSWORD=

# Shipping location for Israel-based pricing
SHIPPING_COUNTRY=United States
SHIPPING_ZIPCODE=
